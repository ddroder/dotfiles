# Font settings
font-family = JetBrainsMono Nerd Font
font-size = 19

# Window settings - no tab bar, minimal decorations
gtk-tabs-location = hidden
macos-titlebar-style = hidden
window-decoration = false

# Background image - dimmed to match Wezterm brightness=0.15
background-image = {{HOME}}/backgrounds/4k_luffy.jpg
background-image-opacity = 0.15

# Dracula theme (matching Wezterm)
theme = Dracula

# Boost text vibrancy to approximate Wezterm foreground_text_hsb
bold-is-bright = true

# macOS Option key bindings for word navigation
# Option+Left = backward-word (Alt+b)
keybind = opt+left=text:\x1bb
# Option+Right = forward-word (Alt+f)
keybind = opt+right=text:\x1bf

# Pass Ctrl+Tab / Ctrl+Shift+Tab to tmux for window switching (CSI u encoding)
keybind = ctrl+tab=text:\x1b[9;5u
keybind = ctrl+shift+tab=text:\x1b[9;6u
